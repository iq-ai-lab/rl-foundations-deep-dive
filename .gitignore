# =============================================================================
# RL Foundations Deep Dive — .gitignore
# =============================================================================

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / Packaging
.Python
build/
dist/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Jupyter Notebook ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
profile_default/
ipython_config.py

# ── NumPy / 직렬화 cache ─────────────────────────────────────────────────────
*.npy
*.npz
*.pkl
*.pickle
*.joblib

# ── Gymnasium / Gym 환경 cache ───────────────────────────────────────────────
.gym_cache/
.gymnasium_cache/

# ── Experiment outputs ───────────────────────────────────────────────────────
# 생성된 시각화·학습 곡선·plot (각 챕터)
# Ch1: MDP 정의 시각화 · Markov property 도식 · POMDP belief state
# Ch2: V^π · Q^π heatmap · Bellman expectation 수렴 곡선
# Ch3: V* · Q* heatmap · greedy policy 시각화
# Ch4: Contraction 시각화 · ‖V_k - V*‖ log plot · γ별 수렴 속도 비교
# Ch5: Value Iteration vs Policy Iteration 수렴 비교 · GPI 사각 다이어그램 · Howard 정책 변화 추적
# Ch6: Performance Difference Lemma 검증 · advantage 분포 · stationary distribution
# Ch7: Linear FA TD(0) 수렴 · Deadly Triad divergence · LSVI-UCB regret
*.png
*.jpg
*.jpeg
*.svg
*.pdf
*.gif
*.mp4
*.webm
*.webp

# 훈련 결과 / 체크포인트
results/
outputs/
logs/
checkpoints/
runs/
wandb/
mlruns/
tensorboard/
tb_logs/
*.log
*.csv
*.tfevents.*

